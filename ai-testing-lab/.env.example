# ==============================================================================
# ai-testing-lab · variables de entorno (Fase 1 - Local)
# Copia este archivo a ".env" y ajusta los valores. No subas ".env" a git.
# ==============================================================================

# ---- Model serving (Ollama) -------------------------------------------------
OLLAMA_PORT=11434
OLLAMA_BASE_URL=http://localhost:11434
# Modelo chat pequeño, corre bien en CPU/laptop. Cambialo por uno mas grande
# si tu hardware lo permite (ej. llama3.1:8b, qwen2.5:7b).
OLLAMA_CHAT_MODEL=llama3.2:1b
# Modelo de embeddings para RAG.
OLLAMA_EMBED_MODEL=nomic-embed-text

# ---- API gateway propia ------------------------------------------------------
API_PORT=8080
API_HOST=0.0.0.0

# ---- Interfaz compatible con OpenAI (para promptfoo / deepeval / ragas) ------
# Ollama expone /v1 compatible con el SDK de OpenAI. La API key no se valida,
# pero muchas librerías exigen que el campo no este vacio.
OPENAI_API_KEY=ollama-local-no-key-needed
OPENAI_BASE_URL=http://localhost:11434/v1
OPENAI_COMPAT_MODEL=llama3.2:1b

# ---- Observabilidad (Arize Phoenix) ------------------------------------------
PHOENIX_UI_PORT=6006
PHOENIX_OTLP_PORT=4317
PHOENIX_COLLECTOR_ENDPOINT=http://localhost:4317
# URL mostrada a clientes (navegador / futura UI Streamlit).
PHOENIX_UI_URL=http://127.0.0.1:6006
# URL de sonda interna (en Docker Compose se sobreescribe a http://phoenix:6006).
# PHOENIX_PROBE_URL=http://127.0.0.1:6006

# ---- Laboratorio / UI-0B ----------------------------------------------------
# Raíz con scripts/, evals/, reports/. En Compose: /lab
# LAB_ROOT=

# ---- UI Streamlit (UI-1A) ----------------------------------------------------
UI_PORT=8501
# Dentro de Compose la UI usa el DNS del servicio API (no localhost).
# AILAB_API_BASE_URL=http://api:8080
# Enlaces visibles en el navegador (host):
AILAB_API_PUBLIC_URL=http://127.0.0.1:8080
AILAB_OPENAPI_DOCS_URL=http://127.0.0.1:8080/docs
AILAB_PHOENIX_PUBLIC_URL=http://127.0.0.1:6006
# Timeout de lectura para POST /chat (inferencia local).
# AILAB_CHAT_READ_TIMEOUT=120
# Timeout de lectura para POST /agents/{skill}/run.
# AILAB_SKILL_READ_TIMEOUT=120
# Timeout de lectura para ingest/query RAG.
# AILAB_RAG_READ_TIMEOUT=180
# Timeout para crear job de eval (POST) y consultar estado (GET).
# AILAB_EVAL_CREATE_TIMEOUT=30
# AILAB_EVAL_READ_TIMEOUT=15
# Zona horaria para timestamps de UI (ej. America/Panama).
# AILAB_UI_TIMEZONE=UTC

# ---- Seguridad / Red teaming --------------------------------------------------
# Endpoint objetivo para garak / promptfoo redteam (normalmente el mismo
# gateway compatible con OpenAI que expone Ollama).
REDTEAM_TARGET_BASE_URL=http://localhost:11434/v1
REDTEAM_TARGET_MODEL=llama3.2:1b

# ---- General ------------------------------------------------------------------
LOG_LEVEL=info
ENVIRONMENT=local
